# =============================================================================
# Agentic Trading Floor — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Required (default mode: all traders use OpenAI) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Required for researcher web search ---
TAVILY_API_KEY=tvly-your-tavily-api-key

# --- Optional: live market data via Massive.com (omit to use built-in simulator) ---
MASSIVE_API_KEY=

# --- Optional: push notifications after trade cycles (Pushover) ---
PUSHOVER_USER=
PUSHOVER_TOKEN=

# --- Optional: assign a different LLM to each trader ---
USE_MANY_MODELS=false
# When USE_MANY_MODELS=true, set keys for the providers you use:
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
OPENROUTER_API_KEY=

# --- Scheduler ---
RUN_EVERY_N_MINUTES=60
RUN_EVEN_WHEN_MARKET_IS_CLOSED=false
